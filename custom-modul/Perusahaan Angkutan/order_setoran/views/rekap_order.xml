<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_rekap_order" model="ir.actions.act_window">
        <field name="name">Rekap Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">rekap.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            </p>
        </field>
    </record>

    <record id="rekap_order_tree_view" model="ir.ui.view">
        <field name="name">rekap.order.tree</field>
        <field name="model">rekap.order</field>
        <field name="arch" type="xml">
            <tree default_order="name desc">
                <field name="name" string="No. Setoran" optional="show"/>
            </tree>
        </field>
    </record>
</odoo>